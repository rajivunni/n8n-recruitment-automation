    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const c = $input.item.json;\n\nconst userContent = `Write a brief, professional LinkedIn recruiter outreach message (120-150 words) to ${c.name}, who is currently ${c.title} at ${c.company}.\\n\\nMention their relevant experience in the ${c.role_title} space and invite them to discuss this opportunity. Be warm but professional. Do not mention salary.\\n\\nReturn only the message text, no subject line, no extra formatting, no greeting label.`;\n\nconst requestBody = {\n  model: 'claude-sonnet-4-20250514',\n  max_tokens: 300,\n  messages: [{ role: 'user', content: userContent }]\n};\n\nreturn [{ json: { ...c, _outreachRequestBody: JSON.stringify(requestBody) } }];"
      },
