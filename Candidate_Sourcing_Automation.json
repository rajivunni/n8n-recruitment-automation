    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst count = items.length;\n\nif (count === 0) {\n  return [{ json: {\n    count: 0,\n    role_title: $('Set Job Requirements').first().json.role_title,\n    top_candidate_name: 'N/A',\n    top_score: 0,\n    sheet_url: 'https://docs.google.com/spreadsheets/d/YOUR_GOOGLE_SHEET_ID'\n  }}];\n}\n\nconst top = items[0].json;\nreturn [{ json: {\n  count: count,\n  role_title: top.role_title,\n  top_candidate_name: top.name,\n  top_score: top.score,\n  sheet_url: 'https://docs.google.com/spreadsheets/d/YOUR_GOOGLE_SHEET_ID'\n}}];"
