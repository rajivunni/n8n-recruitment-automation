      "name": "Set Job Requirements",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [
        -880,
        144
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.apollo.io/v1/mixed_people/search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Cache-Control",
              "value": "no-cache"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ api_key: $env.APOLLO_API_KEY, person_titles: [$json.role_title], q_keywords: $json.required_skills, person_locations: [$json.location], page: 1, per_page: 100 }) }}",
        "options": {}
      },
      "id": "a055ae5d-4179-4bb4-9f3f-cbf62845a13d",
      "name": "Apollo: Search Candidates",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -656,
        144
      ]
    },
    {
      "parameters": {
        "jsCode": "const apolloData = $input.all()[0].json;\nconst people = apolloData.people || [];\nconst jobReqs = $('Set Job Requirements').first().json;\n\nif (people.length === 0) {\n  throw new Error('Apollo returned 0 candidates. Check your search criteria and API key.');\n}\n\nreturn people.map(person => ({\n  json: {\n    // Job requirements (carried through the entire pipeline)\n    role_title: jobReqs.role_title,\n    required_skills: jobReqs.required_skills,\n    years_experience: jobReqs.years_experience,\n    job_location: jobReqs.location,\n    nice_to_have: jobReqs.nice_to_have || '',\n    // Candidate fields\n    name: person.name || '',\n    title: person.title || '',\n    company: (person.organization && person.organization.name) || '',\n    linkedin_url: person.linkedin_url || '',\n    email: person.email || '',\n    location: [person.city, person.state, person.country].filter(Boolean).join(', ')\n  }\n}));"
      },
      "id": "da486c64-a227-48f0-ac93-465d078c73c9",
      "name": "Normalize Candidates",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -448,
        144
      ]
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "53e54e78-d8f8-462a-8018-b58a47272a6a",
      "name": "Score: Loop",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        -224,
        144
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const c = $input.item.json;\n\nconst systemPrompt = 'You are a recruitment expert scoring candidate fit for a job. Return ONLY valid JSON with no markdown, no explanation, no preamble.';\n\nconst userContent = `JOB REQUIREMENTS:\\n- Role: ${c.role_title}\\n- Required Skills: ${c.required_skills}\\n- Years Experience: ${c.years_experience}\\n- Location: ${c.job_location}\\n- Nice to have: ${c.nice_to_have}\\n\\nCANDIDATE PROFILE:\\n- Name: ${c.name}\\n- Current Role: ${c.title}\\n- Company: ${c.company}\\n- Location: ${c.location}\\n\\nSCORING CRITERIA:\\n1. Skills Match (0-40 points): Infer likely skills from their job title and company, compare to required skills\\n2. Experience Level (0-30 points): Does seniority of their current role match the required years?\\n3. Role Relevance (0-20 points): Is their current role similar to the target role?\\n4. Location Match (0-10 points): Are they in the same location or within reasonable commute/relocation distance?\\n\\nReturn ONLY this JSON structure:\\n{\\n  \"score\": <total 0-100>,\\n  \"skills_match\": <0-40>,\\n  \"experience_match\": <0-30>,\\n  \"role_match\": <0-20>,\\n  \"location_match\": <0-10>,\\n  \"reasoning\": \"<2-3 sentence explanation>\",\\n  \"red_flags\": \"<any concerns or empty string>\"\\n}`;\n\nconst requestBody = {\n  model: 'claude-sonnet-4-20250514',\n  max_tokens: 500,\n  system: systemPrompt,\n  messages: [{ role: 'user', content: userContent }]\n};\n\nreturn [{ json: { ...c, _requestBody: JSON.stringify(requestBody) } }];"
      },
      "id": "352eb663-495c-40ea-8559-115072d1e8ec",
      "name": "Build Score Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $env.CLAUDE_API_KEY }}"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ $json._requestBody }}",
        "options": {}
      },
      "id": "4a429fe1-345c-4076-a242-0c59ae2e6ff3",
      "name": "Claude: Score Candidate",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        224,
        0
      ]
    },
    {
      "parameters": {
        "amount": 1
      },
      "id": "4c636e74-2cb3-4151-80d9-5b51b9d19413",
      "name": "Wait 1s (Scoring)",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "webhookId": "9f8e7d6c-0008-4000-a000-000000000008",
      "position": [
        448,
        0
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const claudeResponse = $input.item.json;\nconst candidate = $('Build Score Request').item.json;\nconst content = (claudeResponse.content && claudeResponse.content[0] && claudeResponse.content[0].text) || '';\n\ntry {\n  const cleaned = content.replace(/```json/g, '').replace(/```/g, '').trim();\n  const scored = JSON.parse(cleaned);\n  const { _requestBody, ...candidateData } = candidate;\n  return [{\n    json: {\n      ...candidateData,\n      score: typeof scored.score === 'number' ? scored.score : 0,\n      skills_match: typeof scored.skills_match === 'number' ? scored.skills_match : 0,\n      experience_match: typeof scored.experience_match === 'number' ? scored.experience_match : 0,\n      role_match: typeof scored.role_match === 'number' ? scored.role_match : 0,\n      location_match: typeof scored.location_match === 'number' ? scored.location_match : 0,\n      reasoning: scored.reasoning || '',\n      red_flags: scored.red_flags || ''\n    }\n  }];\n} catch (error) {\n  const { _requestBody, ...candidateData } = candidate;\n  return [{\n    json: {\n      ...candidateData,\n      score: 0,\n      skills_match: 0,\n      experience_match: 0,\n      role_match: 0,\n      location_match: 0,\n      reasoning: 'Error: could not parse score response',\n      red_flags: 'Parse error: ' + error.message\n    }\n  }];\n}"
      },
      "id": "1bdb6ec5-a738-4cdb-95c1-9e8fcc993021",
      "name": "Parse Score",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Filter: keep only score >= 60\nconst filtered = items.filter(item => item.json.score >= 60);\n\n// Sort: descending by score\nconst sorted = filtered.sort((a, b) => b.json.score - a.json.score);\n\n// Limit to top 50\nconst top50 = sorted.slice(0, 50);\n\n// Add rank (1-based)\nreturn top50.map((item, index) => ({\n  json: {\n    rank: index + 1,\n    ...item.json\n  }\n}));"
      },
      "id": "b8e43e35-8ecb-45c7-84fc-8ee2fad38fe8",
      "name": "Filter + Sort + Top 50",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -224,
        352
      ]
    },
    {
      "parameters": {
        "options": {}
