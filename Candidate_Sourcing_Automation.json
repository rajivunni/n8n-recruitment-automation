    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const claudeResponse = $input.item.json;\nconst candidate = $('Build Outreach Request').item.json;\nconst outreachText = (claudeResponse.content && claudeResponse.content[0] && claudeResponse.content[0].text) || '';\nconst { _outreachRequestBody, ...candidateData } = candidate;\nreturn [{\n  json: {\n    ...candidateData,\n    outreach_draft: outreachText.trim()\n  }\n}];"
      },
